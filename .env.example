# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE[?pgbouncer=true&connection_limit=10]
DATABASE_URL="postgresql://quantmail:quantmail@localhost:5432/quantmail"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign Master SSO tokens. Use a strong random value in production.
SSO_SECRET=quantmail-dev-secret

# ─── Biometric Liveness Provider ──────────────────────────────────────────────
# Choose the liveness check provider: "incode" | "microblink" | "local"
# Defaults to "local" (entropy-based heuristic) when no API keys are configured.
LIVENESS_PROVIDER=local

# Incode Omni SDK (https://incode.com)
INCODE_API_KEY=
INCODE_API_URL=https://demo-api.incode.com/omni/start
INCODE_FLOW_ID=

# Microblink BlinkID SDK (https://microblink.com)
MICROBLINK_API_KEY=
MICROBLINK_API_URL=https://api.microblink.com/v1/recognizers/face-liveness
